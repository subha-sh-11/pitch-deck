# ─── Database (Postgres + pgvector) ───────────────────────────────
POSTGRES_USER=pitchdeck
POSTGRES_PASSWORD=pitchdeck
POSTGRES_DB=pitchdeck
# Async URL used by the app runtime
DATABASE_URL=postgresql+asyncpg://pitchdeck:pitchdeck@localhost:5432/pitchdeck
# Sync URL used by Alembic migrations (derived automatically if omitted)
# DATABASE_URL_SYNC=postgresql+psycopg2://pitchdeck:pitchdeck@localhost:5432/pitchdeck

# ─── Redis (cache + Celery broker) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Object storage (MinIO / S3 / R2) ─────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=pitchdeck
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_REGION=us-east-1

# ─── AI providers ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Image generation ─────────────────────────────────────────────
# Provider: vertex | google | fal | replicate | auto | none
IMAGE_PROVIDER=vertex
# Vertex AI (Google Cloud) — service account or ambient ADC. Image model routes by name:
# gemini-* ("Nano Banana") → :generateContent; imagen-* (deprecated, off June 2026) → :predict.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_CREDENTIALS_PATH=
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image     # or gemini-3.1-flash-image (preview)
# API-key alternative (generativelanguage): set IMAGE_PROVIDER=google
GOOGLE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image
# Other diffusion backends
FAL_KEY=
REPLICATE_API_TOKEN=

# ─── Auth ─────────────────────────────────────────────────────────
# Shared secret used to verify NextAuth-issued JWTs on the backend
NEXTAUTH_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ─── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
