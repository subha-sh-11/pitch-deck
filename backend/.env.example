# Backend configuration — copy to backend/.env and edit as needed.
#   cp backend/.env.example backend/.env            (macOS/Linux/Windows bash)
#   Copy-Item backend/.env.example backend/.env     (Windows PowerShell)
# Real environment variables always override this file. Never commit backend/.env.

# ─── Database (Postgres + pgvector) ───────────────────────────────
POSTGRES_USER=pitchdeck
POSTGRES_PASSWORD=pitchdeck
POSTGRES_DB=pitchdeck
# Async URL used by the app runtime
DATABASE_URL=postgresql+asyncpg://pitchdeck:pitchdeck@localhost:5432/pitchdeck
# Sync URL used by Alembic migrations (derived from DATABASE_URL if omitted)
# DATABASE_URL_SYNC=postgresql+psycopg2://pitchdeck:pitchdeck@localhost:5432/pitchdeck

# ─── Redis (cache + Celery broker) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ───────────────────────────────────────────────────────
# Local dev needs no worker: run generation jobs inline.
CELERY_EAGER=true
# For a real worker (needs Redis) leave the above false/blank and run:
#   celery -A app.workers.celery_app:celery_app worker -l info

# ─── Object storage (S3) ──────────────────────────────────────────
# Default: the "floci" S3 emulator from docker compose (port 4566, creds test/test).
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=pitchdeck
S3_KEY=test
S3_SECRET=test
S3_REGION=us-east-1
# MinIO alternative (docker compose up -d minio):
#   S3_ENDPOINT=http://localhost:9000
#   S3_KEY=minioadmin
#   S3_SECRET=minioadmin

# ─── AI text providers (optional — blank = offline/placeholder fallbacks) ──
# auto picks the first provider with a configured key.
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Image generation ─────────────────────────────────────────────
# Provider: fal | vertex | google | replicate | auto | none
#   none  → palette-driven SVG placeholders (no key needed)
#   fal   → set FAL_KEY
#   vertex→ Google Cloud service account (VERTEX_PROJECT + credentials)
IMAGE_PROVIDER=none
FAL_KEY=
REPLICATE_API_TOKEN=
# Vertex AI (Gemini "Nano Banana" image models). Auth via service-account JSON.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_CREDENTIALS_PATH=
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
# API-key (generativelanguage) alternative: set IMAGE_PROVIDER=google
GOOGLE_API_KEY=

# ─── Misc AI ──────────────────────────────────────────────────────
# Real comparable-film posters for the Show Cross slide (free API key)
TMDB_API_KEY=
# When true, never call external AI providers (deterministic fallbacks only)
AI_OFFLINE=false

# ─── Auth ─────────────────────────────────────────────────────────
# Shared secret used to verify NextAuth-issued JWTs on the backend
NEXTAUTH_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ─── App ──────────────────────────────────────────────────────────
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000
