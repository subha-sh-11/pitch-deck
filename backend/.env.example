# Copy to backend/.env and fill in the blanks. NEVER commit your real .env.
# Defaults below assume the Docker infra from docker-compose.yml (postgres/redis/floci).

# ─── Database (Docker Postgres on :5432) ───
DATABASE_URL=postgresql+asyncpg://pitchdeck:pitchdeck@localhost:5432/pitchdeck
DATABASE_URL_SYNC=postgresql+psycopg2://pitchdeck:pitchdeck@localhost:5432/pitchdeck

# ─── Redis (Docker on :6379) ───
REDIS_URL=redis://localhost:6379/0
# true = run generation inline in-request (no Celery worker needed). Great for local dev.
CELERY_EAGER=true

# ─── Object storage — Floci local AWS emulator (S3) on :4566 ───
S3_ENDPOINT=http://localhost:4566
S3_BUCKET=pitchdeck
S3_KEY=test
S3_SECRET=test
S3_REGION=us-east-1

# ─── Auth (admin is seeded on startup; CHANGE THESE) ───
NEXTAUTH_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ─── AI providers (all optional — blank = deterministic offline fallbacks) ───
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Images: auto|fal|replicate|google|vertex|none  (none = SVG placeholders)
IMAGE_PROVIDER=none
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux-pro/v1.1
REPLICATE_API_TOKEN=
GOOGLE_API_KEY=
# Vertex (only if IMAGE_PROVIDER=vertex). Auth via gcloud ADC.
VERTEX_PROJECT=
VERTEX_LOCATION=us-central1
VERTEX_CREDENTIALS_PATH=
VERTEX_IMAGE_MODEL=imagen-4.0-fast-generate-001
# Real comparable-film posters on the Show Cross slide (free key: themoviedb.org/settings/api)
TMDB_API_KEY=

# ─── App ───
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_BASE_URL=http://localhost:8000
AI_OFFLINE=false
