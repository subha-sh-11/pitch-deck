# Frontend configuration (optional) — copy to frontend/.env.local if you need to override.
#   cp frontend/.env.local.example frontend/.env.local
# Defaults to the local backend when unset, so this file is only needed to point at a
# different API host. Never commit frontend/.env.local.

# Base URL the browser uses to reach the FastAPI backend (must include /api/v1).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
